# --- Клиент (Vite) ---
# Секрет для кнопки «Добавить»: совпадает с token в URL (?token=…).
VITE_ADMIN_TOKEN=

# Google Places API key (New Places API v1). Используется для поиска мест в модалке «Новое место».
# Без него поиск работает через Photon (OpenStreetMap) — менее полные данные по бизнесам.
# Получить: https://console.cloud.google.com → APIs & Services → Enable "Places API (New)"
VITE_GOOGLE_PLACES_API_KEY=

# Базовый URL локального API (без слэша в конце). Если задан — каталог и новые места идут через сервер.
# Режим строгий: встроенный catalog.ts и localStorage для мест не подмешиваются — только ответ GET /api/catalog.
VITE_API_BASE_URL=http://localhost:3001

# Устарело: если пусто, POST на добавление = ${VITE_API_BASE_URL}/api/places
# VITE_ADMIN_PLACES_API=

# OSRM для маршрутов авто/автобус по дорогам (по умолчанию router.project-osrm.org)
# VITE_OSRM_BASE_URL=https://router.project-osrm.org

# --- Сервер (Node, см. npm run server:dev) — те же значения в .env в корне или экспорт перед запуском ---
# ADMIN_TOKEN=          # тот же секрет, что VITE_ADMIN_TOKEN (проверка POST /api/places)
# PORT=3001
# DATABASE_PATH=server/data/catalog.sqlite
# CORS_ORIGIN=http://localhost:5173
# Прод (GitHub Pages): Origin в браузере — https://username.github.io без пути к репо. Несколько origin: через запятую.
# CORS_ORIGIN=http://localhost:5173,https://username.github.io
